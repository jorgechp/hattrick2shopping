{
  "manifest_version": 3,
  "name": "Hattrick2Shopping",
  "version": "0.1.0",
  "description": "Captura datos de transferencias de Hattrick para análisis de mercado",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost/*",
    "https://hattrick2shopping-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.hattrick.org/*/Transfer*"],
      "js": ["content-script.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hattrick2shopping@jorgechp.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Hattrick2Shopping"
  }
}
